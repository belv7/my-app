<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>TASK BLOCK</title>
  <style>
    @import url("https://fonts.googleapis.com/css2?family=DotGothic16&family=Press+Start+2P&display=swap");

    :root {
      color-scheme: light;
      --ink: #16122b;
      --bg: #1d1830;
      --panel: #f7efc8;
      --panel-hi: #fff9de;
      --line: #3b305f;
      --muted: #5b5670;
      --accent: #23b17b;
      --accent-deep: #12765a;
      --danger: #d04f3a;
      --warning: #d4931f;
      --info: #426fd1;
      --pixel-shadow: 0 4px 0 #211a3d;
      --board-bg: #202731;
      --board-cell: #2f3a47;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--ink);
      font-family: "DotGothic16", "Hiragino Kaku Gothic ProN", sans-serif;
      background:
        repeating-linear-gradient(0deg, #221b37 0, #221b37 16px, #2a2242 16px, #2a2242 32px),
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0, rgba(255, 255, 255, 0.03) 16px, transparent 16px, transparent 32px);
    }

    .shell {
      max-width: 1180px;
      margin: 0 auto;
      padding: 24px 16px 40px;
    }

    .hero {
      display: grid;
      gap: 12px;
      margin-bottom: 16px;
      padding: 14px;
      background: linear-gradient(180deg, #fff7d7, #f0e3b8);
      border: 4px solid var(--line);
      box-shadow: var(--pixel-shadow);
    }

    .eyebrow {
      margin: 0;
      color: var(--accent-deep);
      font-family: "Press Start 2P", monospace;
      font-size: 0.66rem;
      line-height: 1.7;
    }

    h1 {
      margin: 0;
      font-family: "Press Start 2P", monospace;
      font-size: clamp(1.1rem, 2.3vw, 1.8rem);
      line-height: 1.5;
      text-shadow: 2px 2px 0 #ffe17a;
      max-width: 19ch;
    }

    .summary {
      margin: 0;
      color: var(--muted);
      line-height: 1.45;
      font-size: 1rem;
    }

    .status-bar {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
    }

    .status-chip {
      padding: 10px;
      border: 3px solid var(--line);
      background: #fff8df;
      box-shadow: 0 3px 0 #2f2750;
    }

    .status-chip strong {
      display: block;
      margin-bottom: 3px;
      font-family: "Press Start 2P", monospace;
      font-size: 0.75rem;
      line-height: 1.5;
    }

    .status-chip span {
      color: var(--muted);
      font-size: 0.9rem;
    }

    .grid {
      display: grid;
      grid-template-columns: 0.95fr 1.05fr;
      gap: 14px;
      align-items: start;
    }

    .stack {
      display: grid;
      gap: 14px;
    }

    .card {
      background: var(--panel);
      border: 4px solid var(--line);
      box-shadow: var(--pixel-shadow);
    }

    .card-inner {
      padding: 14px;
    }

    .section-title {
      margin: 0 0 10px;
      font-family: "Press Start 2P", monospace;
      font-size: 0.7rem;
      line-height: 1.7;
      color: #2a2046;
    }

    .section-note {
      margin: 0 0 10px;
      color: var(--muted);
      line-height: 1.45;
      font-size: 0.95rem;
    }

    .hint-note {
      margin: 0;
      padding: 10px;
      background: #ecfff7;
      border: 2px solid #52a184;
      color: #155844;
      font-weight: 700;
      line-height: 1.45;
    }

    form {
      display: grid;
      gap: 10px;
    }

    label {
      display: block;
      margin-bottom: 6px;
      font-size: 0.95rem;
      font-weight: 700;
      color: #2a2046;
    }

    input[type="text"],
    input[type="number"],
    input[type="datetime-local"],
    textarea,
    select {
      width: 100%;
      min-height: 44px;
      padding: 10px 12px;
      border: 3px solid #4f456e;
      background: var(--panel-hi);
      border-radius: 0;
      color: var(--ink);
      font: inherit;
      outline: none;
      box-shadow: inset 0 -2px 0 rgba(38, 31, 61, 0.14);
    }

    textarea {
      min-height: 96px;
      resize: vertical;
    }

    input:focus,
    textarea:focus,
    select:focus {
      border-color: var(--accent-deep);
      box-shadow: inset 0 -2px 0 rgba(17, 116, 91, 0.35), 0 0 0 2px #cff5e8;
    }

    .small-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .primary,
    .secondary,
    .danger,
    .info-btn {
      min-height: 44px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 12px;
      border: 3px solid #352c57;
      border-radius: 0;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
    }

    .primary:disabled,
    .secondary:disabled,
    .danger:disabled,
    .info-btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      box-shadow: none;
    }

    .primary {
      background: linear-gradient(180deg, #2ecf9c, #1b946d);
      color: #082a1f;
      box-shadow: 0 3px 0 #16573f;
    }

    .secondary {
      background: #fff8df;
      color: var(--ink);
      box-shadow: 0 3px 0 #a9945f;
    }

    .danger {
      background: #ffd9cf;
      color: #6e1e0f;
      box-shadow: 0 3px 0 #a45344;
    }

    .info-btn {
      background: #d7e6ff;
      color: #16376a;
      box-shadow: 0 3px 0 #5776a6;
    }

    .task-list {
      display: grid;
      gap: 10px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .task {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 12px;
      border: 3px solid #4f456e;
      background: #fff8df;
      box-shadow: 0 3px 0 #ad9862;
    }

    .task.completed {
      background: #f0ead0;
      border-color: #6d628f;
    }

    .task.completed .task-title {
      color: #5b5570;
      text-decoration: line-through;
      text-decoration-thickness: 2px;
    }

    .task-meta {
      display: grid;
      gap: 6px;
    }

    .task-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .badge {
      min-height: 28px;
      display: inline-flex;
      align-items: center;
      padding: 3px 8px;
      border: 2px solid;
      font-weight: 700;
      font-size: 0.8rem;
    }

    .badge-city {
      background: #dbd2fa;
      color: #2f2551;
      border-color: #66589d;
    }

    .badge-danger {
      background: #ffd5cd;
      color: #6b1709;
      border-color: #a74b3d;
    }

    .badge-warning {
      background: #ffe3ab;
      color: #5a3b00;
      border-color: #9f7820;
    }

    .badge-safe {
      background: #cbf0e5;
      color: #124739;
      border-color: #387766;
    }

    .task-title {
      margin: 0;
      font-size: 1rem;
      font-weight: 800;
      line-height: 1.35;
    }

    .task-description,
    .task-status {
      margin: 0;
      color: var(--muted);
      line-height: 1.4;
      font-size: 0.92rem;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .edit-panel {
      margin-top: 8px;
      border-top: 2px dashed #7b6fa9;
      padding-top: 8px;
    }

    .edit-panel summary {
      min-height: 44px;
      display: flex;
      align-items: center;
      cursor: pointer;
      list-style: none;
      color: #2d2450;
      font-weight: 800;
    }

    .edit-panel summary::-webkit-details-marker {
      display: none;
    }

    .edit-panel summary::before {
      content: ">";
      margin-right: 8px;
      font-family: "Press Start 2P", monospace;
      font-size: 0.7rem;
    }

    .edit-panel[open] summary::before {
      content: "v";
    }

    .edit-form {
      margin-top: 8px;
      display: grid;
      gap: 10px;
    }

    .tetris-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 240px;
      gap: 12px;
      align-items: start;
    }

    .board-shell {
      background: #0f1320;
      border: 4px solid #2d3f58;
      box-shadow: 0 3px 0 #081120;
      padding: 8px;
      position: relative;
    }

    .game-over-banner {
      position: absolute;
      inset: 8px;
      display: none;
      align-items: center;
      justify-content: center;
      background: rgba(10, 14, 24, 0.78);
      color: #ffd166;
      font-family: "Press Start 2P", monospace;
      font-size: clamp(1rem, 3vw, 1.4rem);
      letter-spacing: 0.06em;
      text-shadow: 0 2px 0 #000;
      z-index: 2;
      pointer-events: none;
    }

    .game-over-banner.visible {
      display: flex;
    }

    #tetris-board {
      width: 100%;
      max-width: 460px;
      aspect-ratio: 1 / 2;
      background: var(--board-bg);
      border: 3px solid #4d5d72;
      image-rendering: pixelated;
      display: block;
      margin: 0 auto;
    }

    .game-side {
      display: grid;
      gap: 10px;
    }

    .stock-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .stock-item {
      border: 2px solid #4f456e;
      background: #fff8df;
      padding: 8px;
      display: grid;
      gap: 3px;
      cursor: pointer;
    }

    .stock-item.active {
      border-color: #1b8f6b;
      background: #e9fff7;
    }

    .stock-item.disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }

    .stock-item strong {
      font-family: "Press Start 2P", monospace;
      font-size: 0.72rem;
      line-height: 1.4;
    }

    .stock-item span {
      color: var(--muted);
      font-size: 0.88rem;
    }

    .controls-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .controls-grid button {
      min-height: 44px;
    }

    .stat-list {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 6px;
    }

    .stat-row {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      border: 2px solid #4f456e;
      background: #fff8df;
      padding: 6px 8px;
      font-size: 0.92rem;
    }

    .stat-row-highlight {
      border-color: #1b8f6b;
      background: #e9fff7;
      font-weight: 800;
    }

    .task.hidden-task {
      display: none;
    }

    .show-all-wrap {
      margin-top: 10px;
      display: flex;
      justify-content: center;
    }

    [hidden] {
      display: none !important;
    }

    .flash {
      animation: flash-line 220ms steps(2, end);
    }

    @keyframes flash-line {
      0% { filter: brightness(1); }
      50% { filter: brightness(1.8); }
      100% { filter: brightness(1); }
    }

    .empty {
      margin: 0;
      border: 3px dashed #655a92;
      background: #fff8df;
      color: var(--muted);
      padding: 16px;
      line-height: 1.5;
      text-align: center;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    @media (max-width: 980px) {
      .status-bar {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .tetris-layout {
        grid-template-columns: 1fr;
      }

      .game-side {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .shell {
        padding: 14px 12px 30px;
      }

      .hero,
      .card-inner {
        padding: 12px;
      }

      .status-bar,
      .small-grid,
      .game-side {
        grid-template-columns: 1fr;
      }

      .task {
        grid-template-columns: 1fr;
      }

      .actions,
      .actions form,
      .actions button {
        width: 100%;
      }
    }
  </style>
</head>
<body>
  <main class="shell">
    <header class="hero">
      <p class="eyebrow">TASK BLOCK</p>
      <h1>TASK BLOCK</h1>
      <div class="status-bar" aria-label="主要ステータス">
        <div class="status-chip"><strong><%= stats.totalTasks %></strong><span>総タスク数</span></div>
        <div class="status-chip"><strong><%= stats.completionRate %>%</strong><span>完了率</span></div>
        <div class="status-chip"><strong><%= stats.totalAcquiredMinos %></strong><span>総獲得ミノ</span></div>
        <div class="status-chip"><strong id="status-user-level">Lv <%= stats.userLevel %></strong><span>ユーザーレベル</span></div>
      </div>
    </header>

    <div class="grid">
      <div class="stack">
        <section class="card">
          <div class="card-inner">
            <h2 class="section-title">メモ</h2>
            <% const urgent30Count = tasks.filter((task) => {
              if (task.completed || !task.dueDate) return false;
              const remaining = new Date(task.dueDate).getTime() - Date.now();
              return remaining > 0 && remaining <= 30 * 60 * 1000;
            }).length; %>
            <p class="section-note">今日は <%= stats.completedTasks %> 件進んだ。未完了は <%= Math.max(0, stats.totalTasks - stats.completedTasks) %> 件。</p>
            <p class="section-note">⚠️締め切り30分以内のタスクは<span id="urgent30-count"><%= urgent30Count %></span>件</p>
          </div>
        </section>

        <section class="card">
          <div class="card-inner">
            <h2 class="section-title">新しいタスク</h2>
            <form action="/tasks" method="post">
              <div>
                <label for="title">タスク名</label>
                <input id="title" type="text" name="title" placeholder="例: 仕様レビューを終える" required maxlength="120">
              </div>
              <div>
                <label for="description">詳細説明</label>
                <textarea id="description" name="description" placeholder="例: 重要論点を3つに要約して共有"></textarea>
              </div>
              <div>
                <label for="dueDate">締切日時</label>
                <input id="dueDate" type="datetime-local" name="dueDate">
                <input type="hidden" name="dueDateUtc" value="">
              </div>
              <button class="primary" type="submit">タスクを追加</button>
            </form>
          </div>
        </section>

        <section class="card">
          <div class="card-inner">
            <h2 class="section-title">タスク一覧</h2>
            <% const pendingTasks = tasks.filter((task) => !task.completed); %>
            <% const completedTasks = tasks.filter((task) => task.completed); %>
            <% if (pendingTasks.length === 0) { %>
              <p class="empty">未完了タスクはありません。</p>
            <% } else { %>
              <ul class="task-list" id="pending-task-list">
                <% pendingTasks.forEach((task, index) => { %>
                <li class="task <%= index >= 10 ? ' hidden-task' : '' %>" data-task-group="pending" <%= index >= 10 ? 'hidden' : '' %>>
                    <div aria-hidden="true">○</div>
                    <div class="task-meta">
                      <p class="task-title"><%= task.title %></p>
                      <% if (task.description) { %>
                        <p class="task-description"><%= task.description %></p>
                      <% } %>
                      <div class="task-badges">
                        <span class="badge badge-safe"><%= task.statusLabel %></span>
                      </div>

                      <details class="edit-panel">
                        <summary>編集</summary>
                        <form class="edit-form" action="/tasks/<%= task.id %>/edit" method="post">
                          <div>
                            <label for="edit-title-<%= task.id %>">タスク名</label>
                            <input id="edit-title-<%= task.id %>" type="text" name="title" value="<%= task.title %>" required maxlength="120">
                          </div>
                          <div>
                            <label for="edit-description-<%= task.id %>">詳細説明</label>
                            <textarea id="edit-description-<%= task.id %>" name="description"><%= task.description %></textarea>
                          </div>
                          <div>
                            <label for="edit-dueDate-<%= task.id %>">締切日時</label>
                            <input id="edit-dueDate-<%= task.id %>" type="datetime-local" name="dueDate" value="<%= task.dueDateInput %>">
                            <input type="hidden" name="dueDateUtc" value="">
                          </div>
                          <button class="secondary" type="submit">変更を保存</button>
                        </form>
                      </details>
                    </div>
                    <div class="actions">
                      <form action="/tasks/<%= task.id %>/toggle" method="post" class="toggle-form" data-task-id="<%= task.id %>" data-completed="0">
                        <input type="hidden" name="rewardAction" value="stock">
                        <button class="secondary" type="submit">完了にする</button>
                      </form>
                      <form action="/tasks/<%= task.id %>/duplicate" method="post">
                        <button class="secondary" type="submit">複製</button>
                      </form>
                      <form action="/tasks/<%= task.id %>/delete" method="post" onsubmit="return confirm('このタスクを削除しますか？');">
                        <button class="danger" type="submit">削除</button>
                      </form>
                    </div>
                  </li>
                <% }) %>
              </ul>
              <% if (pendingTasks.length > 10) { %>
                <div class="show-all-wrap">
                  <button id="show-all-pending-tasks" class="secondary" type="button">すべてを表示</button>
                </div>
              <% } %>
            <% } %>
          </div>
        </section>
      </div>

      <div class="stack">
        <section class="card">
          <div class="card-inner">
              <h2 class="section-title">ゲーム</h2>
            <p class="section-note">操作: ← → 移動 / ↑ 回転 / ↓ ソフトドロップ / Space ハードドロップ</p>
            <div class="tetris-layout">
              <div class="board-shell">
                <canvas id="tetris-board" width="300" height="600" aria-label="テトリス盤面"></canvas>
                <div id="game-over-banner" class="game-over-banner">GAME OVER</div>
              </div>
              <div class="game-side">
                <div>
                  <h3 class="section-title" style="margin-bottom:8px;">ミノストック</h3>
                  <div id="stock-grid" class="stock-grid"></div>
                </div>

                <div>
                  <h3 class="section-title" style="margin-bottom:8px;">操作</h3>
                  <div class="controls-grid">
                    <button id="spawn-piece" class="primary" type="button">ゲームスタート</button>
                    <button id="rotate-piece" class="info-btn" type="button">回転</button>
                    <button id="move-left" class="secondary" type="button">左</button>
                    <button id="move-right" class="secondary" type="button">右</button>
                    <button id="soft-drop" class="secondary" type="button">落下</button>
                    <button id="hard-drop" class="danger" type="button">一気に落下</button>
                  </div>
                </div>

                <div>
                  <h3 class="section-title" style="margin-bottom:8px;">統計</h3>
                  <ul class="stat-list">
                    <li class="stat-row stat-row-highlight"><span>総獲得ミノ数</span><strong id="stat-total-minos">0</strong></li>
                    <li class="stat-row"><span>総ライン消去数</span><strong id="stat-total-lines">0</strong></li>
                    <li class="stat-row"><span>最大コンボ数</span><strong id="stat-max-combo">0</strong></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="card">
          <div class="card-inner">
            <h2 class="section-title">過去のタスク</h2>
            <% if (completedTasks.length === 0) { %>
              <p class="empty">完了タスクはまだありません。</p>
            <% } else { %>
              <ul class="task-list" id="past-task-list">
                <% completedTasks.forEach((task, index) => { %>
                <li class="task completed <%= index >= 10 ? ' hidden-task' : '' %>" data-task-group="past" <%= index >= 10 ? 'hidden' : '' %>>
                    <div aria-hidden="true">✓</div>
                    <div class="task-meta">
                      <p class="task-title"><%= task.title %></p>
                      <% if (task.description) { %>
                        <p class="task-description"><%= task.description %></p>
                      <% } %>
                      <div class="task-badges">
                        <span class="badge badge-safe"><%= task.statusLabel %></span>
                      </div>

                      <details class="edit-panel">
                        <summary>編集</summary>
                        <form class="edit-form" action="/tasks/<%= task.id %>/edit" method="post">
                          <div>
                            <label for="edit-title-<%= task.id %>">タスク名</label>
                            <input id="edit-title-<%= task.id %>" type="text" name="title" value="<%= task.title %>" required maxlength="120">
                          </div>
                          <div>
                            <label for="edit-description-<%= task.id %>">詳細説明</label>
                            <textarea id="edit-description-<%= task.id %>" name="description"><%= task.description %></textarea>
                          </div>
                          <div>
                            <label for="edit-dueDate-<%= task.id %>">締切日時</label>
                            <input id="edit-dueDate-<%= task.id %>" type="datetime-local" name="dueDate" value="<%= task.dueDateInput %>">
                            <input type="hidden" name="dueDateUtc" value="">
                          </div>
                          <button class="secondary" type="submit">変更を保存</button>
                        </form>
                      </details>
                    </div>
                    <div class="actions">
                      <form action="/tasks/<%= task.id %>/duplicate" method="post">
                        <button class="secondary" type="submit">複製</button>
                      </form>
                      <form action="/tasks/<%= task.id %>/delete" method="post" onsubmit="return confirm('このタスクを削除しますか？');">
                        <button class="danger" type="submit">削除</button>
                      </form>
                    </div>
                  </li>
                <% }) %>
              </ul>
              <% if (completedTasks.length > 10) { %>
                <div class="show-all-wrap">
                  <button id="show-all-past-tasks" class="secondary" type="button">すべてを表示</button>
                </div>
              <% } %>
            <% } %>
          </div>
        </section>
      </div>
    </div>
  </main>
  <script>
    (() => {
      const colors = {
        I: "#4cc9f0",
        O: "#ffd166",
        T: "#c77dff",
        S: "#80ed99",
        Z: "#ff6b6b",
        J: "#4d7cfe",
        L: "#f7b267",
        X: "#8b8f98",
      };

      const shapeDefs = {
        I: [[1, 1, 1, 1]],
        O: [[1, 1], [1, 1]],
        T: [[0, 1, 0], [1, 1, 1]],
        S: [[0, 1, 1], [1, 1, 0]],
        Z: [[1, 1, 0], [0, 1, 1]],
        J: [[1, 0, 0], [1, 1, 1]],
        L: [[0, 0, 1], [1, 1, 1]],
      };

      const rewardTable = { 1: 120, 2: 360, 3: 720, 4: 1200 };
      const boardCanvas = document.getElementById("tetris-board");
      const ctx = boardCanvas ? boardCanvas.getContext("2d") : null;
      if (!boardCanvas || !ctx) {
        return;
      }

      const cols = 10;
      const rows = 20;
      const cell = 30;
      const maxStock = 2;
      const storageKey = "taskboard-tetris-v1";
      const totalAcquiredMinos = Number(<%- JSON.stringify(stats.totalAcquiredMinos) %> || 0);
      const initialUserLevel = Math.max(1, Number(<%- JSON.stringify(stats.userLevel) %> || 1));
      const seedPieces = <%- JSON.stringify(tetrisSeedPieces) %>;
      const deadlineTasks = <%- JSON.stringify(tasks.map((task) => ({
        id: task.id,
        completed: task.completed,
        dueDate: task.dueDate,
      }))) %>;

      function rotateMatrix(mat) {
        return mat[0].map((_, i) => mat.map((row) => row[i]).reverse());
      }

      function cloneBoard(board) {
        return board.map((row) => row.slice());
      }

      function createBoard() {
        return Array.from({ length: rows }, () => Array(cols).fill(null));
      }

      function defaultState() {
        const initialStockQueue = seedPieces.slice(0, maxStock).map((piece) => ({
          token: piece.token,
          taskId: piece.taskId,
          type: piece.type,
          title: piece.title || "",
        }));

        return {
          stockQueue: initialStockQueue,
          board: createBoard(),
          stats: {
            displayTotalMinos: totalAcquiredMinos,
            userLevel: initialUserLevel,
            totalLines: 0,
            single: 0,
            double: 0,
            triple: 0,
            tetris: 0,
            maxCombo: 0,
            combo: 0,
            xp: 0,
            coins: 0,
            event: "待機中",
          },
          deadlineTriggers: {},
          pendingHazards: 0,
          gameOver: false,
          selectedToken: initialStockQueue[0]?.token || null,
        };
      }

      function readState() {
        try {
          const raw = localStorage.getItem(storageKey);
          if (!raw) return defaultState();
          const parsed = JSON.parse(raw);
          if (!Array.isArray(parsed.board) || parsed.board.length !== rows) return defaultState();
          const merged = { ...defaultState(), ...parsed, stats: { ...defaultState().stats, ...(parsed.stats || {}) } };
          merged.stockQueue = Array.isArray(merged.stockQueue)
            ? merged.stockQueue
                .filter((token) => Number.isInteger(Number(token?.taskId)) && Number(token.taskId) > 0)
                .slice(0, maxStock)
            : [];
          if (!merged.selectedToken || !merged.stockQueue.some((item) => item.token === merged.selectedToken)) {
            merged.selectedToken = merged.stockQueue[0]?.token || null;
          }
          if (!Number.isFinite(merged.stats.displayTotalMinos)) {
            merged.stats.displayTotalMinos = totalAcquiredMinos;
          }
          if (!Number.isFinite(merged.stats.userLevel) || merged.stats.userLevel < 1) {
            merged.stats.userLevel = initialUserLevel;
          }
          return merged;
        } catch {
          return defaultState();
        }
      }

      function saveState() {
        localStorage.setItem(storageKey, JSON.stringify(state));
      }

      function setGameOverVisible(isVisible) {
        const banner = document.getElementById("game-over-banner");
        if (!banner) return;
        banner.classList.toggle("visible", Boolean(isVisible));
      }

      function getAvailableTokens() {
        if (!Array.isArray(state.stockQueue)) {
          state.stockQueue = [];
        }
        return state.stockQueue.slice(0, maxStock);
      }

      function getMinoTypeForTask(taskId) {
        const normalized = Math.abs(Math.trunc(taskId));
        let mixed = (normalized + 0x9e3779b9) >>> 0;
        mixed = (mixed ^ (mixed >>> 16)) >>> 0;
        mixed = Math.imul(mixed, 0x85ebca6b) >>> 0;
        mixed = (mixed ^ (mixed >>> 13)) >>> 0;
        mixed = Math.imul(mixed, 0xc2b2ae35) >>> 0;
        mixed = (mixed ^ (mixed >>> 16)) >>> 0;
        const types = ["I", "O", "T", "S", "Z", "J", "L"];
        return types[mixed % types.length];
      }

      function enqueueStockToken(token) {
        const queue = getAvailableTokens().filter((item) => item.token !== token.token);
        queue.push(token);
        while (queue.length > maxStock) {
          queue.shift();
        }
        state.stockQueue = queue;
        if (!state.selectedToken || !queue.some((item) => item.token === state.selectedToken)) {
          state.selectedToken = queue[0]?.token || null;
        }
      }

      function popTokenById(tokenId) {
        const queue = getAvailableTokens();
        const idx = queue.findIndex((item) => item.token === tokenId);
        if (idx < 0) return null;
        const target = queue[idx];
        queue.splice(idx, 1);
        state.stockQueue = queue;
        state.selectedToken = queue[0]?.token || null;
        saveState();
        return target;
      }

      function createActivePiece(type) {
        const shape = shapeDefs[type].map((row) => row.slice());
        const candidate = {
          type,
          shape,
          x: Math.floor((cols - shape[0].length) / 2),
          y: -1,
          color: null,
          isHazard: false,
        };
        if (collides(candidate.x, candidate.y, candidate.shape)) {
          return null;
        }
        return candidate;
      }

      function getRandomHazardShape() {
        const keys = Object.keys(shapeDefs);
        const key = keys[Math.floor(Math.random() * keys.length)];
        return shapeDefs[key].map((row) => row.slice());
      }

      function resetKeyStatsOnTopOut() {
        state.stats.displayTotalMinos = 0;
        state.stats.userLevel = 1;
        state.stats.totalLines = 0;
        state.stats.maxCombo = 0;
        state.stats.single = 0;
        state.stats.double = 0;
        state.stats.triple = 0;
        state.stats.tetris = 0;
        state.stats.combo = 0;
        state.stats.event = "天井到達で統計をリセットしました";
      }

      function triggerGameOver() {
        state.board = createBoard();
        active = null;
        state.pendingHazards = 0;
        state.gameOver = true;
        resetKeyStatsOnTopOut();
        setGameOverVisible(true);
      }

      function isTopReached() {
        return Array.isArray(state.board[0]) && state.board[0].some(Boolean);
      }

      function enforceTopOutResetIfNeeded() {
        if (!isTopReached()) return;
        triggerGameOver();
        saveState();
      }

      function spawnHazardFromTop() {
        if (active) return false;
        const shape = getRandomHazardShape();
        const maxX = cols - shape[0].length;
        const x = Math.floor(Math.random() * (maxX + 1));
        const candidate = {
          type: "X",
          shape,
          x,
          y: -1,
          color: colors.X,
          isHazard: true,
        };

        if (collides(candidate.x, candidate.y, candidate.shape)) {
          triggerGameOver();
          saveState();
          render();
          return false;
        }

        active = candidate;
        render();
        return true;
      }

      function trySpawnPendingHazard() {
        if (active) return;
        if (!state.pendingHazards || state.pendingHazards <= 0) return;
        state.pendingHazards -= 1;
        spawnHazardFromTop();
        saveState();
      }

      function queueDeadlineHazard(reasonLabel) {
        state.pendingHazards = (state.pendingHazards || 0) + 1;
        state.stats.event = `${reasonLabel}でグレーミノが落下`;
        trySpawnPendingHazard();
      }

      function watchDeadlineHazards() {
        const thresholds = [30, 10, 5];

        const tick = () => {
          renderUrgentDeadlineCount();
          const now = Date.now();
          for (const task of deadlineTasks) {
            if (!task || task.completed || !task.dueDate) continue;
            const dueAt = new Date(task.dueDate).getTime();
            if (!Number.isFinite(dueAt)) continue;
            const remainingMs = dueAt - now;
            if (remainingMs <= 0) continue;

            for (const threshold of thresholds) {
              const key = `${task.id}-${threshold}`;
              if (state.deadlineTriggers[key]) continue;
              if (remainingMs <= threshold * 60 * 1000) {
                state.deadlineTriggers[key] = true;
                queueDeadlineHazard(`締切まで${threshold}分`);
              }
            }
          }
          saveState();
        };

        renderUrgentDeadlineCount();
        tick();
        window.setInterval(tick, 15000);
      }

      function applyRewardFromQuery() {
        const clearRewardQuery = () => {
          const url = new URL(window.location.href);
          url.searchParams.delete("rewardAction");
          url.searchParams.delete("rewardTaskId");
          const clean = `${url.pathname}${url.search}${url.hash}`;
          window.history.replaceState({}, "", clean || "/");
        };

        const params = new URLSearchParams(window.location.search);
        const rawTaskId = params.get("rewardTaskId");
        if (rawTaskId == null) {
          return;
        }

        const actionRaw = String(params.get("rewardAction") || "stock").toLowerCase();
        const action = actionRaw === "start" ? "start" : "stock";
        const rewardTaskId = Number(rawTaskId);
        if (!Number.isInteger(rewardTaskId)) {
          clearRewardQuery();
          return;
        }

        const token = {
          token: `task-${rewardTaskId}`,
          taskId: rewardTaskId,
          type: getMinoTypeForTask(rewardTaskId),
          title: "",
        };

        if (action === "stock") {
          enqueueStockToken(token);
          state.stats.displayTotalMinos += 1;
          setEvent(`ストック追加: ${token.type}`);
        } else {
          const candidate = createActivePiece(token.type);
          if (candidate) {
            active = candidate;
            state.stats.displayTotalMinos += 1;
            setEvent(`ゲームスタート: ${token.type}`);
          } else {
            enqueueStockToken(token);
            state.stats.displayTotalMinos += 1;
            setEvent(`盤面が詰まっているため ${token.type} をストックに回しました`);
          }
        }

        saveState();
        clearRewardQuery();
      }

      function popToken(type) {
        const selectedTokenId = state.selectedToken;
        const target = selectedTokenId ? popTokenById(selectedTokenId) : null;
        if (!target) return null;
        if (type && target.type !== type) {
          const fallback = getAvailableTokens().find((item) => item.type === type);
          if (fallback) {
            enqueueStockToken(target);
            return popTokenById(fallback.token);
          }
        }
        return target;
      }

      function spawn(type) {
        if (active) return;
        const token = popToken(type);
        if (!token) {
          setEvent("そのミノの在庫がありません");
          renderStock();
          return;
        }
        const shape = shapeDefs[type].map((row) => row.slice());
        active = {
          type,
          shape,
          x: Math.floor((cols - shape[0].length) / 2),
          y: -1,
          color: null,
          isHazard: false,
        };
        state.gameOver = false;
        setGameOverVisible(false);
        if (collides(active.x, active.y, active.shape)) {
          triggerGameOver();
          saveState();
        }
        render();
        renderStock();
      }

      function collides(nx, ny, shape) {
        for (let y = 0; y < shape.length; y += 1) {
          for (let x = 0; x < shape[y].length; x += 1) {
            if (!shape[y][x]) continue;
            const bx = nx + x;
            const by = ny + y;
            if (bx < 0 || bx >= cols || by >= rows) return true;
            if (by >= 0 && state.board[by][bx]) return true;
          }
        }
        return false;
      }

      function lockPiece() {
        if (!active) return;
        for (let y = 0; y < active.shape.length; y += 1) {
          for (let x = 0; x < active.shape[y].length; x += 1) {
            if (!active.shape[y][x]) continue;
            const by = active.y + y;
            const bx = active.x + x;
            if (by >= 0 && by < rows && bx >= 0 && bx < cols) {
              state.board[by][bx] = active.isHazard ? "X" : active.type;
            }
          }
        }

        if (state.board[0].some(Boolean)) {
          triggerGameOver();
        }

        active = null;
        const cleared = clearLines();
        if (cleared > 0) {
          state.stats.combo += 1;
          state.stats.maxCombo = Math.max(state.stats.maxCombo, state.stats.combo);
          state.stats.totalLines += cleared;
          if (cleared === 1) state.stats.single += 1;
          if (cleared === 2) state.stats.double += 1;
          if (cleared === 3) state.stats.triple += 1;
          if (cleared === 4) state.stats.tetris += 1;
          const base = rewardTable[cleared] || 0;
          const comboBonus = Math.max(0, state.stats.combo - 1) * 35;
          state.stats.xp += base + comboBonus;
          state.stats.coins += Math.floor((base + comboBonus) / 12);
          const label = cleared === 4 ? "Tetris" : cleared === 3 ? "Triple" : cleared === 2 ? "Double" : "Single";
          setEvent(`${label}! combo x${state.stats.combo}`);
          flashBoard();
          playLineSound(cleared, state.stats.combo);
        } else {
          state.stats.combo = 0;
        }
        saveState();
        trySpawnPendingHazard();
        render();
        renderStats();
        renderStock();
      }

      function clearLines() {
        const remained = state.board.filter((row) => row.some((cell) => !cell));
        const removed = rows - remained.length;
        while (remained.length < rows) {
          remained.unshift(Array(cols).fill(null));
        }
        state.board = remained;
        return removed;
      }

      function move(dx, dy, forced = false) {
        if (!active) return;
        if (active.isHazard && !forced) return;
        const nx = active.x + dx;
        const ny = active.y + dy;
        if (!collides(nx, ny, active.shape)) {
          active.x = nx;
          active.y = ny;
          render();
          return;
        }
        if (dy === 1) {
          lockPiece();
        }
      }

      function hardDrop() {
        if (!active) return;
        if (active.isHazard) return;
        while (!collides(active.x, active.y + 1, active.shape)) {
          active.y += 1;
        }
        lockPiece();
      }

      function rotateActive() {
        if (!active) return;
        if (active.isHazard) return;
        const rotated = rotateMatrix(active.shape);
        if (!collides(active.x, active.y, rotated)) {
          active.shape = rotated;
          render();
          return;
        }
        if (!collides(active.x - 1, active.y, rotated)) {
          active.x -= 1;
          active.shape = rotated;
          render();
          return;
        }
        if (!collides(active.x + 1, active.y, rotated)) {
          active.x += 1;
          active.shape = rotated;
          render();
        }
      }

      function drawCell(x, y, color) {
        ctx.fillStyle = color;
        ctx.fillRect(x * cell, y * cell, cell, cell);
        ctx.strokeStyle = "rgba(255,255,255,0.15)";
        ctx.lineWidth = 1;
        ctx.strokeRect(x * cell + 0.5, y * cell + 0.5, cell - 1, cell - 1);
      }

      function renderBoard() {
        ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue("--board-bg").trim();
        ctx.fillRect(0, 0, boardCanvas.width, boardCanvas.height);

        for (let y = 0; y < rows; y += 1) {
          for (let x = 0; x < cols; x += 1) {
            const type = state.board[y][x];
            if (!type) {
              ctx.fillStyle = "#2b3541";
              ctx.fillRect(x * cell, y * cell, cell, cell);
              ctx.strokeStyle = "rgba(0,0,0,0.2)";
              ctx.strokeRect(x * cell + 0.5, y * cell + 0.5, cell - 1, cell - 1);
            } else {
                drawCell(x, y, colors[type] || colors.X);
            }
          }
        }

        if (active) {
          for (let y = 0; y < active.shape.length; y += 1) {
            for (let x = 0; x < active.shape[y].length; x += 1) {
              if (!active.shape[y][x]) continue;
              const bx = active.x + x;
              const by = active.y + y;
              if (by >= 0) drawCell(bx, by, active.color || colors[active.type] || colors.X);
            }
          }
        }
      }

      function renderStats() {
        document.getElementById("stat-total-minos").textContent = String(state.stats.displayTotalMinos);
        document.getElementById("stat-total-lines").textContent = String(state.stats.totalLines);
        document.getElementById("stat-max-combo").textContent = String(state.stats.maxCombo);
        const levelEl = document.getElementById("status-user-level");
        if (levelEl) {
          levelEl.textContent = `Lv ${Math.max(1, Number(state.stats.userLevel) || 1)}`;
        }
      }

      function renderUrgentDeadlineCount() {
        const urgentCount = deadlineTasks.filter((task) => {
          if (!task || task.completed || !task.dueDate) return false;
          const dueAt = new Date(task.dueDate).getTime();
          if (!Number.isFinite(dueAt)) return false;
          const remaining = dueAt - Date.now();
          return remaining > 0 && remaining <= 30 * 60 * 1000;
        }).length;

        const urgentCountEl = document.getElementById("urgent30-count");
        if (urgentCountEl) {
          urgentCountEl.textContent = String(urgentCount);
        }
      }

      function setEvent(message) {
        state.stats.event = message;
      }

      function renderStock() {
        const queue = getAvailableTokens();
        const grid = document.getElementById("stock-grid");
        const spawnButton = document.getElementById("spawn-piece");
        if (!state.selectedToken || !queue.some((item) => item.token === state.selectedToken)) {
          state.selectedToken = queue[0]?.token || null;
        }

        spawnButton.disabled = !state.selectedToken;

        grid.innerHTML = "";
        if (queue.length === 0) {
          return;
        }

        queue.forEach((token, idx) => {
          const item = document.createElement("button");
          item.type = "button";
          item.className = "stock-item" + (state.selectedToken === token.token ? " active" : "");
          item.innerHTML = `<strong>${token.type}</strong><span>${idx + 1} 番目のストック</span>`;
          item.addEventListener("click", () => {
            state.selectedToken = token.token;
            saveState();
            renderStock();
          });
          grid.appendChild(item);
        });
      }

      function wireToggleChoiceFlow() {
        const forms = document.querySelectorAll("form.toggle-form");
        forms.forEach((form) => {
          const hidden = form.querySelector('input[name="rewardAction"]');
          if (!hidden) {
            return;
          }

          form.addEventListener("submit", (event) => {
            const isCompleted = form.dataset.completed === "1";
            if (isCompleted) {
              hidden.value = "stock";
              return;
            }
            hidden.value = "stock";
          });
        });
      }

      function migrateLegacyState() {
        if (Array.isArray(state.stockQueue)) {
          return;
        }

        const legacyTokens = seedPieces.filter((piece) => !Array.isArray(state.consumedTokens) || !state.consumedTokens.includes(piece.token));
        state.stockQueue = legacyTokens.slice(0, maxStock).map((piece) => ({
          token: piece.token,
          taskId: piece.taskId,
          type: piece.type,
          title: piece.title || "",
        }));
        state.selectedToken = state.stockQueue[0]?.token || null;
        saveState();
      }

      function flashBoard() {
        boardCanvas.classList.remove("flash");
        boardCanvas.offsetWidth;
        boardCanvas.classList.add("flash");
      }

      let audioCtx = null;
      function ensureAudio() {
        if (!audioCtx) {
          audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        }
      }

      function beep(freq, time, gain) {
        if (!audioCtx) return;
        const osc = audioCtx.createOscillator();
        const amp = audioCtx.createGain();
        osc.type = "square";
        osc.frequency.value = freq;
        amp.gain.value = gain;
        osc.connect(amp);
        amp.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + time);
      }

      function playLineSound(lines, combo) {
        ensureAudio();
        if (!audioCtx) return;
        const base = [220, 330, 440, 660][Math.min(lines - 1, 3)] || 220;
        beep(base, 0.08, 0.03);
        beep(base * 1.5, 0.08, 0.02);
        if (combo >= 2) {
          beep(base * 2, 0.12, 0.03);
        }
      }

      function computeHint() {
        const board = cloneBoard(state.board);
        let near = 0;
        for (const row of board) {
          const filled = row.filter(Boolean).length;
          if (filled === cols - 1) near += 1;
        }
        if (near > 0) {
          return `あと ${near} 箇所で1列揃いそうです。`; 
        }
        const stock = getAvailableTokens().length;
        if (stock === 0) {
          return "ミノ在庫がありません。タスク完了で補充しましょう。";
        }
        const selected = getAvailableTokens().find((token) => token.token === state.selectedToken);
        return `在庫ミノ ${stock} 個。次は ${selected?.type || "任意"} ミノで形を作るのがおすすめです。`;
      }

      function render() {
        renderBoard();
        renderStats();
        setGameOverVisible(state.gameOver);
      }

      function wireTaskListLimit() {
        const wireGroup = (groupName, buttonId) => {
          const items = Array.from(document.querySelectorAll(`[data-task-group='${groupName}']`));
          if (items.length <= 10) return;
          const showAllButton = document.getElementById(buttonId);
          if (!showAllButton) return;

          showAllButton.addEventListener("click", () => {
            items.forEach((item) => {
              item.classList.remove("hidden-task");
              item.hidden = false;
            });
            showAllButton.remove();
          });
        };

        wireGroup("pending", "show-all-pending-tasks");
        wireGroup("past", "show-all-past-tasks");
      }

      function wireDueDateUtcSerialization() {
        const forms = Array.from(document.querySelectorAll("form"));
        forms.forEach((form) => {
          const dueDateInput = form.querySelector("input[name='dueDate']");
          const dueDateUtcInput = form.querySelector("input[name='dueDateUtc']");
          if (!(dueDateInput instanceof HTMLInputElement) || !(dueDateUtcInput instanceof HTMLInputElement)) {
            return;
          }

          form.addEventListener("submit", () => {
            const raw = String(dueDateInput.value || "").trim();
            if (!raw) {
              dueDateUtcInput.value = "";
              return;
            }

            const parsed = new Date(raw);
            dueDateUtcInput.value = Number.isNaN(parsed.getTime()) ? "" : parsed.toISOString();
          });
        });
      }

      const state = readState();
      let active = null;
      let lastDrop = 0;
      let dropInterval = 700;

      migrateLegacyState();
      applyRewardFromQuery();
      enforceTopOutResetIfNeeded();
      wireToggleChoiceFlow();
      wireTaskListLimit();
      wireDueDateUtcSerialization();
      watchDeadlineHazards();

      function gameLoop(ts) {
        if (!lastDrop) lastDrop = ts;
        const delta = ts - lastDrop;
        if (active && delta > dropInterval) {
          move(0, 1, true);
          lastDrop = ts;
        }
        requestAnimationFrame(gameLoop);
      }

      document.getElementById("spawn-piece").addEventListener("click", () => {
        ensureAudio();
        const selected = getAvailableTokens().find((token) => token.token === state.selectedToken);
        if (!selected) {
          setEvent("在庫ミノがありません");
          renderStats();
          return;
        }
        spawn(selected.type);
      });
      document.getElementById("rotate-piece").addEventListener("click", () => { ensureAudio(); rotateActive(); });
      document.getElementById("move-left").addEventListener("click", () => { ensureAudio(); move(-1, 0); });
      document.getElementById("move-right").addEventListener("click", () => { ensureAudio(); move(1, 0); });
      document.getElementById("soft-drop").addEventListener("click", () => { ensureAudio(); move(0, 1); });
      document.getElementById("hard-drop").addEventListener("click", () => { ensureAudio(); hardDrop(); });

      window.addEventListener("keydown", (event) => {
        if (["ArrowLeft", "ArrowRight", "ArrowDown", "ArrowUp", " "].includes(event.key)) {
          event.preventDefault();
          ensureAudio();
        }

        if (event.key === "ArrowLeft") move(-1, 0);
        else if (event.key === "ArrowRight") move(1, 0);
        else if (event.key === "ArrowDown") move(0, 1);
        else if (event.key === "ArrowUp") rotateActive();
        else if (event.key === " ") hardDrop();
      }, { passive: false });

      renderStock();
      render();
      requestAnimationFrame(gameLoop);
    })();
  </script>
</body>
</html>
